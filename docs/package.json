{
  "name": "ruoyi-im-docs",
  "version": "1.0.0",
  "private": true,
  "description": "AI 大模型开发项目文档工具链",
  "scripts": {
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\"",
    "check:links": "node tools/check-links.mjs",
    "check:snippets": "node tools/check-snippets.mjs",
    "build:search": "node tools/generate-search-index.mjs",
    "build:pdf": "node tools/build-offline-pdf.mjs",
    "qa": "npm run lint:md && npm run check:links && npm run check:snippets && npm run build:search && npm run build:pdf"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.18.1",
    "pdfkit": "^0.16.0",
    "yaml": "^2.8.1"
  }
}
