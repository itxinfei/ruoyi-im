  "description": "RuoYi IM UI - DingTalk Style",
  "author": "RuoYi",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.jsx,.vue",
    "lint:fix": "eslint . --ext .js,.jsx,.vue --fix",
    "format": "prettier --write \"src/**/*.{js,vue,scss,css,json}\"",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@vueuse/core": "^11.0.0",
    "axios": "^1.6.2",
    "dayjs": "^1.11.10",
    "dompurify": "^3.0.6",
    "echarts": "^6.0.0",
    "element-plus": "^2.4.4",
    "vue": "^3.3.11",
    "vue-router": "^4.2.5",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "@stylistic/eslint-plugin": "^2.0.0",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "globals": "^15.0.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "sass": "^1.69.5",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.7",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.59.0"
