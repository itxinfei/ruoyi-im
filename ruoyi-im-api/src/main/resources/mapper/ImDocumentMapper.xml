<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.im.mapper.ImDocumentMapper">

    <resultMap type="com.ruoyi.im.domain.ImDocument" id="ImDocumentResult">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="docType" column="doc_type"/>
        <result property="content" column="content"/>
        <result property="status" column="status"/>
        <result property="ownerId" column="owner_id"/>
        <result property="folderId" column="folder_id"/>
        <result property="isStarred" column="is_starred"/>
        <result property="isDeleted" column="is_deleted"/>
        <result property="deletedTime" column="deleted_time"/>
        <result property="autoDeleteDays" column="auto_delete_days"/>
        <result property="lastModifiedBy" column="last_modified_by"/>
        <result property="lastModifiedTime" column="last_modified_time"/>
        <result property="createTime" column="create_time"/>
        <result property="version" column="version"/>
        <result property="parentId" column="parent_id"/>
    </resultMap>

    <sql id="selectImDocumentVo">
        select id, title, doc_type, content, status, owner_id, folder_id,
               is_starred, is_deleted, deleted_time, auto_delete_days,
               last_modified_by, last_modified_time, create_time, version, parent_id
        from im_document
    </sql>

    <select id="selectUserDocuments" resultMap="ImDocumentResult">
        <include refid="selectImDocumentVo"/>
        where owner_id = #{userId}
        and is_deleted = 0
        <if test="!includeShared">
            and folder_id is null
        </if>
        order by last_modified_time desc
    </select>

    <select id="selectSharedDocuments" resultMap="ImDocumentResult">
        <include refid="selectImDocumentVo"/>
        where owner_id != #{userId}
        and is_deleted = 0
        and id in (
            select document_id from im_document_collaborator where user_id = #{userId}
        )
        order by last_modified_time desc
    </select>

    <select id="selectStarredDocuments" resultMap="ImDocumentResult">
        <include refid="selectImDocumentVo"/>
        where owner_id = #{userId}
        and is_starred = 1
        and is_deleted = 0
        order by last_modified_time desc
    </select>

    <select id="selectDeletedDocuments" resultMap="ImDocumentResult">
        <include refid="selectImDocumentVo"/>
        where owner_id = #{userId}
        and is_deleted = 1
        order by deleted_time desc
    </select>

</mapper>