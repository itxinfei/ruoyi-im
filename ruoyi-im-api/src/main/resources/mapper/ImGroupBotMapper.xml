<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.im.mapper.ImGroupBotMapper">

    <resultMap type="com.ruoyi.im.domain.ImGroupBot" id="ImGroupBotResult">
        <id property="id" column="id"/>
        <result property="groupId" column="group_id"/>
        <result property="botName" column="bot_name"/>
        <result property="botType" column="bot_type"/>
        <result property="avatar" column="avatar"/>
        <result property="description" column="description"/>
        <result property="isEnabled" column="is_enabled"/>
        <result property="webhookToken" column="webhook_token"/>
        <result property="secretKey" column="secret_key"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectImGroupBotVo">
        select id, group_id, bot_name, bot_type, avatar, description, is_enabled, webhook_token, secret_key, create_time, update_time
        from im_group_bot
    </sql>

    <select id="selectByGroupId" resultMap="ImGroupBotResult">
        <include refid="selectImGroupBotVo"/>
        where group_id = #{groupId}
    </select>

    <select id="selectEnabledBots" resultMap="ImGroupBotResult">
        <include refid="selectImGroupBotVo"/>
        where is_enabled = 1
    </select>

    <select id="selectEnabledByGroupId" resultMap="ImGroupBotResult">
        <include refid="selectImGroupBotVo"/>
        where group_id = #{groupId}
        and is_enabled = 1
    </select>

    <select id="countByGroupId" resultType="int">
        select count(*)
        from im_group_bot
        where group_id = #{groupId}
    </select>

    <select id="selectByGroupIds" resultMap="ImGroupBotResult">
        <include refid="selectImGroupBotVo"/>
        where group_id in
        <foreach collection="groupIds" item="groupId" open="(" separator="," close=")">
            #{groupId}
        </foreach>
    </select>

</mapper>